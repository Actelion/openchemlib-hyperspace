{
  "inputs": {
    "rawFull": "/path/to/hyperspace.rawspace.gz",
    "rawDownsampled": "/path/to/hyperspace_downsampled.rawspace.gz"
  },
  "query": {
    "smiles": "c1ccc(cc1)NC(=O)N",
    "idcode": null,
    "sdfFile": null,
    "phesaFile": null,
    "sdfRecordIndex": 0
  },
  "queryFile": null,
  "sampling": {
    "attemptsPerReaction": 20,
    "minAtoms": 1,
    "maxAtoms": 0,
    "maxRotatableBonds": 15,
    "minSimilarity": 0.65
  },
  "microOptimization": {
    "enabled": true,
    "request": {
      "beamSize": 5,
      "neighborPoolSize": 4,
      "sampledNeighbors": 4,
      "perPositionCap": 2,
      "maxRounds": 2,
      "patience": 1,
      "minPhesaSimilarity": 0.0,
      "minScoreThreshold": 0.0,
      "improvementTolerance": 0.0001,
      "reportAllCandidates": true,
      "randomSeed": null,
      "logLevel": "SUMMARY"
    }
  },
  "fullOptimization": {
    "request": {
      "beamSize": 10,
      "neighborPoolSize": 8,
      "sampledNeighbors": 4,
      "perPositionCap": 2,
      "maxRounds": 6,
      "patience": 3,
      "minPhesaSimilarity": 0.6,
      "minScoreThreshold": 0.0,
      "improvementTolerance": 0.0001,
      "reportAllCandidates": true,
      "randomSeed": null,
      "logLevel": "SUMMARY"
    }
  },
  "orchestration": {
    "workerThreads": 64,
    "queueCapacity": 1000,
    "progressIntervalSeconds": 60,
    "reactionWeightExponent": 1.0,
    "reactionMinWeight": 0.01,
    "reactionWeighting": {
      "mode": "BUCKETED_PRODUCT",
      "buckets": [
        { "maxProductExclusive": 2000, "weight": 0.01 },
        { "maxProductExclusive": 50000, "weight": 0.1 },
        { "maxProductExclusive": 750000, "weight": 0.5 },
        { "weight": 5.0 }
      ]
    },
    "duplicateCacheSize": 200000
  },
  "run": {
    "maxRuntime": "24h",
    "randomSeed": null
  },
  "output": {
    "hitsTsv": "screening_hits.tsv",
    "minReportedSimilarity": 0.6
  }
}
